rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // driver_profiles — any authenticated user can read (needed for rider-to-driver matching)
    match /driver_profiles/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // rides — any authenticated user can read/write (riders create, drivers update)
    match /rides/{docId} {
      allow read, write: if request.auth != null;
    }

    // rider_profiles — authenticated users can read/write
    match /rider_profiles/{docId} {
      allow read, write: if request.auth != null;
    }

    // All other collections — authenticated users can read/write
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
